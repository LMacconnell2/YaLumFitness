---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import SettingsManager from '../../../components/dashboard/SettingsManager.svelte';

const { user } = Astro.locals;
---

<DashboardLayout title="Settings">
  <div class="settings-header">
    <h1>Settings</h1>
    <p>Manage your account preferences and application limits.</p>
  </div>

  <div class="settings-container">
    <SettingsManager client:load user={user} />
  </div>
</DashboardLayout>

<style>
  .settings-header {
    margin-bottom: 2rem;
  }
  .settings-header h1 { font-size: 1.8rem; font-weight: 800; color: #111827; }
  .settings-header p { color: #6b7280; margin-top: 0.5rem; }

  .settings-container {
    max-width: 600px;
  }
</style>