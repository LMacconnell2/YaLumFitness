---
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import SettingsManager from '../../../components/dashboard/SettingsManager.svelte';

const { user } = Astro.locals;
---

<DashboardLayout title="System Settings">
  <div class="settings-header">
    <h1>System <span class="neon-text-magenta">Configuration</span></h1>
    <p class="subtitle">Modify user parameters and interface protocols.</p>
  </div>

  <div class="settings-container">
    <SettingsManager client:load user={user} />
  </div>
</DashboardLayout>

<style>
  .settings-header {
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #222;
  }
  
  .settings-header h1 { 
    font-size: 2.2rem; 
    font-weight: 800; 
    color: #fff; 
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .neon-text-magenta {
    color: #ff00e6;
    text-shadow: 0 0 15px rgba(255, 0, 230, 0.5);
  }

  .subtitle { 
    color: #666; 
    margin-top: 0.5rem; 
    font-family: monospace;
    font-size: 0.9rem;
  }

  .settings-container {
    max-width: 650px;
    /* Adding a subtle glow to the container area */
    position: relative;
  }
</style>