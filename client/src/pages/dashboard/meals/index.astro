---
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import MealPlanGenerator from '../../../components/dashboard/MealPlanGenerator.svelte';
import MealPlanCard from '../../../components/dashboard/MealPlanCard.svelte';

const { user } = Astro.locals;
const cookie = Astro.request.headers.get("cookie") || "";

const [mealsRes, surveysRes] = await Promise.all([
  fetch("http://localhost:3000/api/v1/meals", { headers: { cookie } }),
  fetch("http://localhost:3000/api/v1/survey", { headers: { cookie } })
]);

const meals = mealsRes.ok ? await mealsRes.json() : [];
const surveys = surveysRes.ok ? await surveysRes.json() : [];

// Shape raw meal entries into "plan" cards for the UI
const mealPlans = meals.map((meal: any, i: number) => ({
  id: meal._id,
  name: `Meal Plan – ${new Date(meal.date).toLocaleDateString()}`,
  isDefault: i === 0,
  calories: meal.totalMacros?.calories ?? 0,
  description: `${meal.foodItems?.length ?? 0} items logged • ${meal.time}`
}));
---

<DashboardLayout title="Meal Planning">
  <div class="page-header">
    <div>
      <h1>Meal Planning</h1>
      <p>Fuel your body with AI-generated nutrition plans tailored to your goals.</p>
    </div>
    <MealPlanGenerator client:load {surveys} />
  </div>

  <div class="plans-grid">
    {mealPlans.map(plan => (
      <MealPlanCard client:load {plan} />
    ))}
  </div>
</DashboardLayout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #222;
  }
  
  .page-header h1 { font-size: 2.2rem; font-weight: 800; color: #fff; margin: 0; }
  .subtitle { color: #666; font-family: monospace; margin-top: 0.5rem; }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .page-header { flex-direction: column; gap: 1.5rem; }
  }
</style>