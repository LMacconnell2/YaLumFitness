---
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import PlanGenerator from '../../../components/dashboard/PlanGenerator.svelte';
import PlanList from '../../../components/dashboard/PlanList.svelte';

const cookie = Astro.request.headers.get("cookie") || "";
let workoutPlans = [];
let surveys = [];

if (cookie) {
  // Fetch real plans and surveys from Express
  const [plansRes, surveyRes] = await Promise.all([
    fetch("http://localhost:3000/api/v1/workout", { headers: { cookie } }),
    fetch("http://localhost:3000/api/v1/survey", { headers: { cookie } })
  ]);

  if (plansRes.ok) workoutPlans = await plansRes.ok ? await plansRes.json() : [];
  if (surveyRes.ok) surveys = await surveyRes.json();
}
---

<DashboardLayout title="Workout Plans">
  <div class="page-header">
    <div>
      <h1>Workout Plans</h1>
      <p>Manage your active routines or generate a new AI-powered plan.</p>
    </div>
      <PlanGenerator client:load {surveys} id="gen-modal" />
  </div>

  <PlanList client:load initialPlans={workoutPlans} />

</DashboardLayout>

<script>
  // Simple trigger for the generator modal
  const btn = document.getElementById('open-gen');
  // We can also use a Svelte 'Store' or parent component to handle this toggle
</script>