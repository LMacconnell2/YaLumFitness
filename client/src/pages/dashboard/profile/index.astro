---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
const { user } = Astro.locals;

const cookie = Astro.request.headers.get("cookie") || "";

// In a real app, you'd fetch the extended profile (bio, goal, height) 
// from your MongoDB /api/v1/users/profile endpoint.
const profileDetails = {
  joinedDate: "January 2024",
  fitnessGoal: "Weight Loss",
  height: "5'11\"",
  startingWeight: "210 lbs",
  currentWeight: "185 lbs",
};
---

<DashboardLayout title="My Profile">
  <div class="profile-header">
    <div class="avatar-large">
      {user?.name?.charAt(0) || 'U'}
    </div>
    <div class="header-text">
      <h1>{user?.name || 'User'}</h1>
      <p>Member since {profileDetails.joinedDate}</p>
    </div>
    <button class="btn-primary">Edit Profile</button>
  </div>

  <div class="profile-grid">
    <div class="profile-card">
      <h3>Account Information</h3>
      <div class="info-group">
        <label>Full Name</label>
        <p>{user?.name}</p>
      </div>
      <div class="info-group">
        <label>Email Address</label>
        <p>{user?.email}</p>
      </div>
      <div class="info-group">
        <label>Password</label>
        <p>••••••••••••</p>
        <a href="#" class="change-link">Change Password</a>
      </div>
    </div>

    <div class="profile-card">
      <h3>Physical Stats</h3>
      <div class="stats-row">
        <div class="info-group">
          <label>Height</label>
          <p>{profileDetails.height}</p>
        </div>
        <div class="info-group">
          <label>Current Weight</label>
          <p>{profileDetails.currentWeight}</p>
        </div>
      </div>
      <div class="info-group">
        <label>Primary Goal</label>
        <div class="goal-tag">{profileDetails.fitnessGoal}</div>
      </div>
    </div>

    <div class="profile-card full-width">
      <h3>Connected Apps</h3>
      <div class="connection-item">
        <div class="service">
          <span class="icon">⌚</span>
          <div>
            <strong>Apple Health / Google Fit</strong>
            <p>Sync your daily steps and heart rate</p>
          </div>
        </div>
        <button class="btn-outline">Connect</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<style>
  .profile-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: white;
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    margin-bottom: 2rem;
  }

  .avatar-large {
    width: 80px;
    height: 80px;
    background: #111827;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    border-radius: 50%;
  }

  .header-text h1 { font-size: 1.5rem; font-weight: 800; margin: 0; }
  .header-text p { color: #6b7280; margin: 0.25rem 0 0; }

  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .profile-card {
    background: white;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
  }

  .full-width { grid-column: span 2; }

  .profile-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .info-group { margin-bottom: 1.25rem; }
  .info-group label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .info-group p { font-weight: 500; color: #111827; margin: 0; }

  .stats-row { display: grid; grid-template-columns: 1fr 1fr; }

  .goal-tag {
    display: inline-block;
    background: #eff6ff;
    color: #1e40af;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .change-link { font-size: 0.85rem; color: #3b82f6; text-decoration: none; }

  .connection-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    background: #f9fafb;
    border-radius: 8px;
  }

  .service { display: flex; gap: 1rem; align-items: center; }
  .service .icon { font-size: 1.5rem; }
  .service p { font-size: 0.85rem; color: #6b7280; margin: 0; }

  .btn-primary {
    margin-left: auto;
    background: #111827;
    color: white;
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-outline {
    background: white;
    border: 1px solid #d1d5db;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
  }

  @media (max-width: 1024px) {
    .profile-grid { grid-template-columns: 1fr; }
    .full-width { grid-column: span 1; }
    .profile-header { flex-direction: column; text-align: center; }
    .btn-primary { margin: 0; width: 100%; }
  }
</style>