---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import SurveyManager from '../../../components/dashboard/SurveyManager.svelte';

const { user } = Astro.locals;
const cookie = Astro.request.headers.get("cookie") || "";

// Mock data: In reality, fetch from http://localhost:3000/api/v1/surveys
const surveyHistory = [
  { id: '1', date: '2024-03-15', goal: 'Muscle Gain', weight: '185 lbs' },
  { id: '2', date: '2024-01-10', goal: 'Weight Loss', weight: '210 lbs' },
];
---

<DashboardLayout title="My Surveys">
  <div class="page-header">
    <div>
      <h1>Fitness Assessments</h1>
      <p>View your past results or take a new assessment to update your plan.</p>
    </div>
    <SurveyManager client:load />
  </div>

  <section class="history-section">
    <div class="content-card">
      <h3>Assessment History</h3>
      {surveyHistory.length > 0 ? (
        <table class="survey-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Primary Goal</th>
              <th>Weight at Time</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {surveyHistory.map(item => (
              <tr>
                <td>{new Date(item.date).toLocaleDateString()}</td>
                <td><span class="badge">{item.goal}</span></td>
                <td>{item.weight}</td>
                <td><button class="text-btn">View Details</button></td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <div class="empty-state">
          <p>You haven't taken any surveys yet.</p>
        </div>
      )}
    </div>
  </section>
</DashboardLayout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .page-header h1 { font-size: 1.8rem; font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: #6b7280; }

  .content-card {
    background: white;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
  }

  .survey-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
  }

  .survey-table th {
    text-align: left;
    font-size: 0.75rem;
    text-transform: uppercase;
    color: #9ca3af;
    padding: 1rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .survey-table td {
    padding: 1rem;
    border-bottom: 1px solid #f3f4f6;
    font-size: 0.95rem;
  }

  .badge {
    background: #f3f4f6;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .text-btn {
    background: none;
    border: none;
    color: #3b82f6;
    font-weight: 600;
    cursor: pointer;
  }
</style>