---
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import SurveyManager from '../../../components/dashboard/SurveyManager.svelte';
import SurveyHistory from '../../../components/dashboard/SurveyHistory.svelte';

const cookie = Astro.request.headers.get("cookie");

let surveyHistory = [];
let fetchError = false;

if (cookie) {
  try {
    const res = await fetch("http://localhost:3000/api/v1/survey/", {
      headers: { 
        "cookie": cookie // Forward the browser's session cookie to Express
      }
    });
    
    if (res.ok) {
      surveyHistory = await res.json();
    } else if (res.status === 401) {
       // If the backend says unauthorized, the cookie might be expired
       return Astro.redirect('/login');
    }
  } catch (err) {
    console.error("Connection to backend failed:", err);
    fetchError = true;
  }
} else {
  // No cookie found at all? Send them back to login
  return Astro.redirect('/login');
}
---

<DashboardLayout title="My Surveys">
  <div class="page-header">
    <div>
      <h1>Fitness Assessments</h1>
      <p>View your past results or take a new assessment to update your plan.</p>
    </div>
    <SurveyManager client:load />
  </div>

  <section class="history-section">
    <SurveyHistory client:load history={surveyHistory} />
  </section>
</DashboardLayout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .page-header h1 { font-size: 1.8rem; font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: #6b7280; }

  .content-card {
    background: white;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
  }

  .survey-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
  }

  .survey-table th {
    text-align: left;
    font-size: 0.75rem;
    text-transform: uppercase;
    color: #9ca3af;
    padding: 1rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .survey-table td {
    padding: 1rem;
    border-bottom: 1px solid #f3f4f6;
    font-size: 0.95rem;
  }

  .badge {
    background: #f3f4f6;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .text-btn {
    background: none;
    border: none;
    color: #3b82f6;
    font-weight: 600;
    cursor: pointer;
  }
</style>