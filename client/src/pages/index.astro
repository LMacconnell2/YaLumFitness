---
import BaseLayout from '../layouts/Layout.astro';
import '../css/home.css';
---

<BaseLayout title="Fitness Tracker | Your Journey, Tracked.">
  <section class="hero">
    <div class="hero-content">
      <h1>Welcome to Your Fitness Journey!</h1>
      <p>The all-in-one platform to track your workouts, monitor nutrition, and visualize your progress.</p>
      <div class="cta-group">
        <a href="/register" class="btn-primary">Sign Up</a>
        <a href="/login" class="btn-secondary">Log In</a>
      </div>
    </div>
    <div class="hero-image">
      <img src="https://picsum.photos/id/43/800/600" alt="Person training" />
    </div>
  </section>

  <section id="features" class="section">
    <h2>Features</h2>
    <div class="card-grid">
      <div class="card">
        <img src="https://picsum.photos/id/0/300/200" alt="Laptop" />
        <h3>Workout Logging</h3>
        <p>Keep a detailed record of every set, rep, and personal best.</p>
      </div>
      <div class="card">
        <img src="https://picsum.photos/id/292/300/200" alt="Healthy food" />
        <h3>Nutrition Tracking</h3>
        <p>Break down your macros and stay on top of your daily calorie goals.</p>
      </div>
      <div class="card">
        <img src="https://picsum.photos/id/180/300/200" alt="Laptop" />
        <h3>Live Analytics</h3>
        <p>Watch your progress unfold with beautiful, interactive charts.</p>
      </div>
    </div>
  </section>

  <section id="benefits" class="section alt-bg">
    <div class="split-view">
      <div class="image-wrap">
        <img src="https://picsum.photos/id/225/600/400" alt="Running" />
      </div>
      <div class="text-wrap">
        <h2>Benefits</h2>
        <ul>
          <li><strong>Consistency:</strong> Build habits that last a lifetime.</li>
          <li><strong>Clarity:</strong> Know exactly what you ate and how you moved.</li>
          <li><strong>Motivation:</strong> See your visual trends and reach new heights.</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="get-started" class="section cta-footer">
    <h2>Ready to transform?</h2>
    <p>Join thousands of users reaching their goals today.</p>
    <a href="/register" class="btn-primary large">Start Your Free Assessment</a>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 4rem;
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .hero-content { flex: 1; }
  .hero-image img { width: 100%; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
  
  h1 { font-size: 3rem; margin-bottom: 1.5rem; line-height: 1.1; }
  .cta-group { display: flex; gap: 1rem; margin-top: 2rem; }

  .section { padding: 5rem 2rem; text-align: center; max-width: 1200px; margin: 0 auto; }
  .alt-bg { background: #f9fafb; max-width: 100%; }
  
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }
  .card { 
    background: white; 
    padding: 1.5rem; 
    border-radius: 8px; 
    border: 1px solid #eee;
    transition: transform 0.2s;
  }
  .card:hover { transform: translateY(-5px); }
  .card img { width: 100%; border-radius: 4px; margin-bottom: 1rem; }

  .split-view { display: flex; align-items: center; gap: 4rem; text-align: left; }
  .image-wrap, .text-wrap { flex: 1; }
  .image-wrap img { width: 100%; border-radius: 12px; }

  .btn-primary { background: #000; color: #fff; padding: 0.8rem 1.5rem; border-radius: 6px; text-decoration: none; font-weight: bold; }
  .btn-secondary { border: 1px solid #000; color: #000; padding: 0.8rem 1.5rem; border-radius: 6px; text-decoration: none; }
  
  .cta-footer { background: #000; color: #fff; border-radius: 12px; margin-bottom: 4rem; }
  .cta-footer p { margin-bottom: 2rem; opacity: 0.8; }
  .large { background: #fff; color: #000; display: inline-block; }

  @media (max-width: 768px) {
    .hero, .split-view { flex-direction: column; text-align: center; }
    h1 { font-size: 2.2rem; }
  }
</style>